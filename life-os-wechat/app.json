/**
 * app.json
 * 文件用途：微信小程序的全局配置文件，配置小程序的页面路径、窗口样式、导航栏等
 * 所属模块：life-os-wechat（微信小程序模块）
 * 核心职责：
 * 1. 定义小程序的页面路径
 * 2. 配置小程序的窗口样式
 * 3. 配置小程序的底部导航栏
 * 4. 配置小程序的其他全局设置
 * 与其他模块的关联：影响所有页面的显示和行为
 * 在整体业务流程中的位置：位于微信小程序的配置层，为整个应用提供全局配置
 * 说明：使用JSON格式定义小程序的全局配置
 */

{
  "pages": [
    "pages/index/index",
    "pages/stat/stat",
    "pages/checklist/checklist",
    "pages/note/note",
    "pages/bill/bill",
    "pages/login/login",
    "pages/profile/profile",
    "pages/logs/logs"
  ],
  "window": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "MoBe",
    "navigationBarBackgroundColor": "#ffffff"
  },
  "tabBar": {
    "color": "#a6a1ab",
    "selectedColor": "#5f5b66",
    "backgroundColor": "#ffffff",
    "borderStyle": "black",
    "list": [
      {
        "pagePath": "pages/stat/stat",
        "text": "统计"
      },
      {
        "pagePath": "pages/checklist/checklist",
        "text": "清单"
      },
      {
        "pagePath": "pages/index/index",
        "text": "首页"
      },
      {
        "pagePath": "pages/note/note",
        "text": "笔记"
      },
      {
        "pagePath": "pages/bill/bill",
        "text": "账单"
      }
    ]
  },
  "style": "v2",
  "componentFramework": "glass-easel",
  "sitemapLocation": "sitemap.json",
  "lazyCodeLoading": "requiredComponents"
}