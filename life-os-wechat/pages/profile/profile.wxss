.page {
  min-height: 100vh;
  background: linear-gradient(120deg, #fdfbfb 0%, #ebedee 100%);
  padding: 28rpx;
  box-sizing: border-box;
}

.page-header {
  padding: 8rpx 4rpx 12rpx;
}

.page-title {
  font-size: 48rpx;
  font-weight: 600;
  color: #5f5b66;
}

.page-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #7f7a84;
}

.content-card {
  margin-top: 24rpx;
  padding: 32rpx 24rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 12rpx 30rpx rgba(80, 90, 110, 0.06);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #5f5b66;
}

.card-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #8a8590;
}